NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB local (instalar MongoDB Community o usar MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/nexusstock

# Secrets: mínimo 32 caracteres — usa un generador para producción
JWT_ACCESS_SECRET=nexusstock-access-secret-dev-key-32chars
JWT_REFRESH_SECRET=nexusstock-refresh-secret-dev-key-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=nexusstock-cookie-secret-dev-key-32chars

# Cloudinary — obtener desde cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=nexusstock/products